# ──────────────────────────────────────────────────────────────────────────
# Pet Manager / EduGuide AI — Environment Variables
# Copy to ".env" before deploying: cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# System
NODE_ENV="production"

# ─── Authentication (NextAuth.js) ──────────────────────────────────────────
# Generate: `openssl rand -base64 32`  (or: `node -e "console.log(crypto.randomBytes(32).toString('base64'))"`)
AUTH_SECRET="please-generate-a-strong-random-value"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3002"

# ─── App / Compose ─────────────────────────────────────────────────────────
APP_PORT="3002"
POSTGRES_PORT="5433"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="petmanager"

# ─── Database ──────────────────────────────────────────────────────────────
# Inside docker-compose use the service hostname "postgres":
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/petmanager"
# When connecting from your host machine, use the published port (POSTGRES_PORT):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/petmanager"

# ─── Optional: Supabase (only if you swap from local Postgres) ─────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ─── LLM via OpenRouter ────────────────────────────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_SITE_URL="http://localhost:3002"
OPENROUTER_SITE_NAME="Pet Manager"
OPENROUTER_MODEL_ROADMAP="openai/gpt-4o-mini"
OPENROUTER_MODEL_QUIZ="openai/gpt-4o-mini"
OPENROUTER_MODEL_FLASHCARDS="google/gemini-2.5-flash-lite"

# ─── Email (Resend) ────────────────────────────────────────────────────────
# Leave as "re_dummy" to log mock emails to the console instead of sending
RESEND_API_KEY="re_dummy"

# ─── Background jobs (Inngest) ─────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Redis (rate limiter) ──────────────────────────────────────────────────
# Inside docker-compose use the service hostname "redis":
REDIS_URL="redis://redis:6379"
# Production (Upstash): "rediss://default:<token>@<endpoint>:<port>"
